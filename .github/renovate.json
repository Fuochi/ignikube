{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticPrefixFix"
  ],
  "argocd": {
    "fileMatch": [
      "application-.*\\.ya?ml$",
      "appproject-.*\\.ya?ml$",
      "applicationset-.*\\.ya?ml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update k3s version in update plans.",
      "managerFilePatterns": [
        "/plan-.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "\\s+version: (?<currentValue>\\S+)"
      ],
      "depNameTemplate": "k3s",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>\\+k3s)(?<build>\\d+)$",
      "datasourceTemplate": "custom.k3s"
    },
    {
      "customType": "regex",
      "description": "Update image version in argocd applications.",
      "fileMatch": [
        "application-.*\\.ya?ml$"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>.+?))?\\s+tag: (?<currentValue>.+?)\\s"
      ]
    },
    {
      "customType": "regex",
      "description": "Update container image references in argocd applications.",
      "fileMatch": [
        "application-.*\\.ya?ml$"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>[^\\s]+?)(?: versioning=(?<versioning>.+?))?\\s+\\S+: [^:\\s]+:(?<currentValue>[^\\s]+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Update Grafana dashboard revisions in GrafanaDashboard CRs.",
      "fileMatch": [
        "dashboard-.*\\.ya?ml$"
      ],
      "matchStrings": [
        "metadata:\\s+name:\\s+(?<depName>\\S+)[\\s\\S]*?grafanaCom:\\s+id:\\s+(?<packageName>\\d+)\\s+revision:\\s+(?<currentValue>\\d+)"
      ],
      "versioningTemplate": "regex:^(?<major>\\d+)$",
      "datasourceTemplate": "custom.grafana-dashboards"
    }
  ],
  "customDatasources": {
    "k3s": {
      "defaultRegistryUrlTemplate": "https://update.k3s.io/v1-release/channels",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $$.(data[id = 'stable'].latest),\"sourceUrl\":\"https://github.com/k3s-io/k3s\",\"changelogUrl\":$join([\"https://github.com/k3s-io/k3s/releases/tag/\",data[id = 'stable'].latest])}],\"sourceUrl\": \"https://github.com/k3s-io/k3s\",\"homepage\": \"https://k3s.io/\"}"
      ]
    },
    "grafana-dashboards": {
      "defaultRegistryUrlTemplate": "https://grafana.com/api/dashboards/{{packageName}}",
      "format": "json",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $string(revision)}]}"
      ]
    }
  }
}
